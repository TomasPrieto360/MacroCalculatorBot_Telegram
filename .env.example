# ============================================
# CONFIGURACIÓN - MACROBOT TELEGRAM
# ============================================
# Renombrá este archivo a .env y completá los valores

# Token de tu bot de Telegram (obtenido de @BotFather)
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# API Key de Google Gemini (para IA generativa)
# Obtenela desde: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Connection String de MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?appName=MacroBotDB
MONGO_URI=mongodb+srv://tu_usuario:tu_password@tu_cluster.mongodb.net/?appName=MacroBotDB

# ============================================
# SOLO PARA RENDER (se configuran automáticamente)
# ============================================
# RENDER_EXTERNAL_URL: se configura solo en Render
# PORT: se configura solo en Render (usualmente 10000)